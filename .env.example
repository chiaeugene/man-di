# Copy to .env and fill in. Never commit the real .env (it's gitignored).

# Supabase Postgres. Project Settings > Database > Connection string.
# DATABASE_URL = pooled (port 6543, "Transaction" mode) — used at runtime.
# DIRECT_URL   = direct (port 5432) — used only by `prisma migrate`.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Single-passcode login (current one-photographer phase). Treat like a password.
APP_PASSCODE=""

# LLM provider: anthropic | openai
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
MANDY_LLM_MODEL=""

# WhatsApp (Meta) — Phase 3 fills these in once a real WhatsApp Business
# Account exists. The webhook route/signature verification/sending code
# already works without them; nothing breaks by leaving them blank for now.
# WHATSAPP_VERIFY_TOKEN: any secret string you choose, entered in the Meta
#   App dashboard's webhook setup to prove you control this URL.
# WHATSAPP_APP_SECRET: from the Meta App's Basic Settings — verifies every
#   inbound webhook actually came from Meta.
# WHATSAPP_ACCESS_TOKEN: a System User's permanent access token, used to
#   send messages/media via the Graph API.
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v21.0"

# Meta Embedded Signup — powers the self-service "Connect with Facebook"
# button on /connect (no manual phone-ID/token copying for the photographer).
# From the Meta App dashboard (same env names as ecommerce-assistant, so one
# Meta app setup can serve both projects):
#   NEXT_PUBLIC_META_APP_ID / META_APP_SECRET: App Settings > Basic. The app
#     id is public by nature (it's shipped to the browser).
#   NEXT_PUBLIC_META_WA_CONFIG_ID: Facebook Login for Business > Configurations —
#     create one with the WhatsApp Embedded Signup flow enabled.
#   META_WA_PIN: optional 6-digit two-step-verification pin used when
#     registering a newly-connected number (default 000000).
META_APP_SECRET=""
NEXT_PUBLIC_META_APP_ID=""
NEXT_PUBLIC_META_WA_CONFIG_ID=""
META_WA_PIN=""

# Shared secret protecting /api/cron/follow-ups (the automated no-reply
# follow-up sweep). Any random string; the cron caller sends it in the
# x-cron-secret header.
CRON_SECRET=""

# Google Calendar — one-time OAuth client from Google Cloud Console. Each
# photographer then self-connects their own calendar from Settings; no
# per-photographer setup needed on our side. Leave blank until registered —
# the Settings page shows "Connect Google Calendar" as unavailable until then.
# Authorized redirect URI to register: <your-app-url>/api/google-calendar/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
